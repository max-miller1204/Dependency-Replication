GET DATA  /TYPE = TXT /FILE = '92CensusStateTypePU.txt' /FIXCASE = 1 /ARRANGEMENT = FIXED /FIRSTCASE = 1 /IMPORTCASE = ALL /VARIABLES = /1  govplus 0-2 A3 govcode 0-1 A2 sttype 2-2 A1 xitem 14-16 A3 amount 17-28 F12 year 29-30 F2 year2 31-32 F2 source 33-34 A2 .CACHE.EXECUTE.string item(A5).compute item=concat("V_",xitem).VARIABLE LABELS GOVPLUS 'Unit and Type code' GOVCODE 'Governments unit code' STTYPE 'Type of Government code' ITEM 'Item code' AMOUNT 'Amount in $1000' YEAR 'Year of Census' YEAR2 'Year of Data' SOURCE 'Source Code'.CACHE.EXECUTE.SAVE OUTFILE= '92CensusStateType.sav'  /DROP=xitem.