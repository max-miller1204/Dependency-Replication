GET DATA  /TYPE = TXT /FILE = '92CensusIndUnit.txt' /FIXCASE = 1 /ARRANGEMENT = FIXED /FIRSTCASE = 1 /IMPORTCASE = ALL /VARIABLES = /1  govcode 0-8 A9 xitem 14-16 A3 amount 17-28 F12 year 29-30 F2 year2 31-32 F2 origin 33-34 F2 .CACHE.EXECUTE.string item (A5).compute item=concat("V_",xitem).VARIABLE LABELS GOVCODE 'Governments unit code' ITEM 'Item code' AMOUNT 'Amount in $1000' YEAR 'Year of Census' YEAR2 'Year of Data' ORIGIN 'Origin Code ' .CACHE.EXECUTE.SAVE OUTFILE= '92CensusIndUnit2.sav'  /DROP=xitem /COMPRESSED.