{com}. * Regressions
. local row = 1
{txt}
{com}. foreach var of varlist ///
>   cs_race_bla cs_race_theil_2000 cs00_seg_inc cs00_seg_inc_pov25 cs00_seg_inc_aff75 frac_traveltime_lt15 ///
>   hhinc00 gini inc_share_1perc gini99 frac_middleclass ///
>   taxrate subcty_total_expenditure_pc eitc_exposure tax_st_diff_top20 ///
>   ccd_exp_tot ccd_pup_tch_ratio score_r dropout_r ///
>   num_inst_pc tuition gradrate_r ///
>   cs_labforce cs_elf_ind_man d_tradeusch_pw_1990 frac_worked1416 ///
>   mig_inflow cs_born_foreign mig_outflow ///
>   scap_ski90pcm rel_tot crime_violent ///
>   cs_fam_wkidsinglemom cs_divorced cs_married {c -(}
{txt}  2{com}.   local col = 1
{txt}  3{com}.   reg e_rank_b `var' if n250
{txt}  4{com}.   su e_rank_b if e(sample)
{txt}  5{com}.   gen eb1 = (e_rank_b-r(mean))/r(sd) if e(sample)
{txt}  6{com}.   su `var' if e(sample)
{txt}  7{com}.   gen v1 = (`var'-r(mean))/r(sd) if e(sample)
{txt}  8{com}.   reg eb1 v1 if n250, cluster(state_id)
{txt}  9{com}.   matrix def beta[`row', `col'] = round(_b[v1], .001)
{txt} 10{com}.   matrix def se[`row', `col'] = round(_se[v1], .001)
{txt} 11{com}.   corr e_rank_b `var' if n250
{txt} 12{com}.   drop eb1 v1
{txt} 13{com}.   local col = 2
{txt} 14{com}.   reg e_rank_b `var' if n250
{txt} 15{com}.   su e_rank_b if e(sample)
{txt} 16{com}.   gen eb2 = (e_rank_b-r(mean))/r(sd) if e(sample)
{txt} 17{com}.   su `var' if e(sample)
{txt} 18{com}.   gen v2 = (`var'-r(mean))/r(sd) if e(sample)
{txt} 19{com}.   areg eb2 v2 if n250, cluster(state_id) absorb(state_id)
{txt} 20{com}.   matrix def beta[`row', `col'] = round(_b[v2], .001)
{txt} 21{com}.   matrix def se[`row', `col'] = round(_se[v2], .001)
{txt} 22{com}.   drop eb2 v2
{txt} 23{com}.   local col = 3
{txt} 24{com}.   reg e_rank_b `var' if n250 [w=pop2000]
{txt} 25{com}.   su e_rank_b if e(sample) [w=pop2000]
{txt} 26{com}.   gen eb3 = (e_rank_b-r(mean))/r(sd) if e(sample)
{txt} 27{com}.   su `var' if e(sample) [w=pop2000]
{txt} 28{com}.   gen v3 = (`var'-r(mean))/r(sd) if e(sample)
{txt} 29{com}.   reg eb3 v3 if n250 [w=pop2000], cluster(state_id)
{txt} 30{com}.   matrix def beta[`row', `col'] = round(_b[v3], .001)
{txt} 31{com}.   matrix def se[`row', `col'] = round(_se[v3], .001)
{txt} 32{com}.   corr e_rank_b `var' if n250 [w=pop2000]
{txt} 33{com}.   drop eb3 v3
{txt} 34{com}.   local col = 4
{txt} 35{com}.   reg e_rank_b `var' if intersects_msa
{txt} 36{com}.   su e_rank_b if intersects_msa & e(sample)
{txt} 37{com}.   gen eb4 = (e_rank_b-r(mean))/r(sd) if intersects_msa & e(sample)
{txt} 38{com}.   su `var' if intersects_msa & e(sample)
{txt} 39{com}.   gen v4 = (`var'-r(mean))/r(sd) if e(sample)
{txt} 40{com}.   reg eb4 v4 if n250 & intersects_msa, cluster(state_id)
{txt} 41{com}.   matrix def beta[`row', `col'] = round(_b[v4], .001)
{txt} 42{com}.   matrix def se[`row', `col'] = round(_se[v4], .001)
{txt} 43{com}.   corr e_rank_b `var' if intersects_msa
{txt} 44{com}.   drop eb4 v4
{txt} 45{com}.   local col = 5
{txt} 46{com}.   if "`var'" != "cs_race_bla" {c -(}
{txt} 47{com}.   * First residualize on race and income growth and then normalize
.   * Residualize e_rank_b
.   reg e_rank_b `var'
{txt} 48{com}.   gen sample = (e(sample) & n250)
{txt} 49{com}.   reg e_rank_b cs_race_bla incgrowth0010 if sample
{txt} 50{com}.   predict e_rank_b_r if sample, res
{txt} 51{com}.   * Residualize RHS
.   reg `var' cs_race_bla incgrowth0010 if sample
{txt} 52{com}.   predict `var'_r if sample, res
{txt} 53{com}.   * Normalize
.   reg e_rank_b_r `var'_r if n250
{txt} 54{com}.   su e_rank_b_r if e(sample)
{txt} 55{com}.   gen eb5 = (e_rank_b_r-r(mean))/r(sd) if e(sample)
{txt} 56{com}.   su `var'_r if e(sample)
{txt} 57{com}.   gen v5 = (`var'_r-r(mean))/r(sd) if e(sample)
{txt} 58{com}.   * Get correlation
.   reg eb5 v5 if sample, cluster(state_id)
{txt} 59{com}.   matrix def beta[`row', `col'] = round(_b[v5], .001)
{txt} 60{com}.   matrix def se[`row', `col'] = round(_se[v5], .001)
{txt} 61{com}.   drop e_rank_b_r eb5 v5 sample
{txt} 62{com}.   {c )-}
{txt} 63{com}.   local col = 6
{txt} 64{com}.   reg s_rank `var' if n250
{txt} 65{com}.   su s_rank if e(sample)
{txt} 66{com}.   gen s6 = (s_rank-r(mean))/r(sd) if e(sample)
{txt} 67{com}.   su `var' if e(sample)
{txt} 68{com}.   gen v6 = (`var'-r(mean))/r(sd) if e(sample)
{txt} 69{com}.   reg s6 v6 if n250, cluster(state_id)
{txt} 70{com}.   matrix def beta[`row', `col'] = round(_b[v6], .001)
{txt} 71{com}.   matrix def se[`row', `col'] = round(_se[v6], .001)
{txt} 72{com}.   corr s_rank `var' if n250
{txt} 73{com}.   drop s6 v6
{txt} 74{com}.   local row = `row' + 1
{txt} 75{com}. {c )-}

