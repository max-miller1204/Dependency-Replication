GET DATA  /TYPE = TXT /FILE = '92CensusIndUnitDirectory.txt' /FIXCASE = 1 /ARRANGEMENT = FIXED /FIRSTCASE = 1 /IMPORTCASE = ALL /VARIABLES = /1  govcode 0-8 A9 supcode 9-13 A5 govname 14-77 A64 region 78-78 F1 coname 79-108 A30 fipstate 109-110 A2 fipsco 111-113 A3 fipspla 114-118 A5 fipsmsa 119-122 A4 fipscmsa 123-124 A2 popetc 125-133 F9 popyr 134-135 F2 schlvl 136-137 A2 ncescode 138-144 A7 weight 145-149 F6.5 fymmdd 152-155 F4 mccode 156-185 A30 recpwt1 186-187 F2 wkhrs 188-188 F1 ftpay 189-189 F1 ptpay 190-190 F1 teachwk 191-192 F2 adminwk 193-194 F2 otherwk 195-196 F2 year 197-198 A2 dschlyr 199-200 F2 retiryr 201-202 F2 finflag 203-203 A1 sform 204-205 A2  .CACHE.EXECUTE.VARIABLE LABELS GOVCODE 'Governments unit code' supcode 'Supplemental codes' govname 'Government Name' region 'Region code' coname 'County Name' fipstate 'FIPS State code' fipsco 'FIPS County code' fipspla 'FIPS Place code' fipsmsa 'FIPS MSA code' fipscmsa 'FIPS CMSA code' popetc 'Pop Enrollment Function etc.' popyr 'Year of pop enrollment Function' schlvl 'School level code' ncescode 'NCES school code' weight 'sample year weight' fymmdd 'Fiscal year end month day' mccode 'Multi-county codes' recpwt1 'Reciprocal weight' wkhrs 'Emp weekly hrs code' ftpay 'Emp full-time pay code' ptpay 'Emp part-time pay code' teachwk 'Months Teachers paid' adminwk 'Months School Admin paid' otherwk 'Months Other School paid' year 'Census Year' dschlyr 'Dependent School Year' retiryr 'Retirement Funds Year' finflag 'Finance Edit Flag' sform 'Survey Form Type' .CACHE.EXECUTE.SORT CASES BY  govcode (A) supcode (A) .EXECUTE.SAVE OUTFILE='92CensusIndUnitID.sav'.