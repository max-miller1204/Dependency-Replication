GET DATA  /TYPE = TXT /FILE = '92CensusCountyArea.txt' /FIXCASE = 1 /ARRANGEMENT = FIXED /FIRSTCASE = 1 /IMPORTCASE = ALL /VARIABLES = /1  govstate 0-1 A2 govco 3-5 A3 xitem 14-16 A3 amount 17-28 F12 year 29-30 F2 year2 31-32 F2 origin 33-34 A2 .CACHE.EXECUTE.string item (A5).compute item=concat("V_",xitem).string govcode (A5) .compute govcode=concat(govstate,govco) .VARIABLE LABELS GOVCODE 'Governments unit code' ITEM 'Item code' AMOUNT 'Amount in $1000' YEAR 'Year of Census' YEAR2 'Year of Data' ORIGIN 'Origin Code ' .SAVE OUTFILE= '92CensusCoArea2.sav'  /DROP=xitem govstate govco /COMPRESSED.