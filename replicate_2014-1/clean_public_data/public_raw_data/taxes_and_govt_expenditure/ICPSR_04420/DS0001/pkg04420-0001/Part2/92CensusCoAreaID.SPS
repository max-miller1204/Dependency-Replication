GET DATA  /TYPE = TXT /FILE = '92CensusCountyAreaDirectory.txt' /FIXCASE = 1 /ARRANGEMENT = FIXED /FIRSTCASE = 1 /IMPORTCASE = ALL /VARIABLES = /1  govstate 0-1 A2 govco 3-5 A3 coname 14-77 A64 fipstate 109-110 A2 fipsco 111-113 A3 popest 125-133 F9  .CACHE.EXECUTE.string govcode (A5) .compute govcode=concat(govstate,govco) .VARIABLE LABELS GOVCODE 'Governments unit code' coname 'County Name' fipstate 'FIPS State code' fipsco 'FIPS County code' popest 'Population Estimate' .SORT CASES BY  govcode (A).EXECUTE.SAVE OUTFILE='92CensusCoAreaID.sav' /DROP=govstate govco /COMPRESSED.